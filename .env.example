# Vite exposes env vars prefixed with VITE_ to the browser bundle.
# Recommended provider: MetaMask Developer / Infura (developer.metamask.io).
# Format: https://<chain>.infura.io/v3/<API_KEY>
VITE_MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
VITE_SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# Optional: WalletConnect project ID. Without this, MetaMask injection still works.
VITE_WALLETCONNECT_PROJECT_ID=YOUR_WC_PROJECT_ID
